<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#F5F7FF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:paddingTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_previous_month"
            android:layout_width="28dp"
            android:layout_height="24dp"
            android:background="@drawable/widget_day_cell"
            android:clickable="true"
            android:contentDescription="@string/organizer_calendar_previous_month"
            android:gravity="center"
            android:text="&lt;"
            android:textColor="#F5F7FF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_month_label"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="#AEB8D4"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_next_month"
            android:layout_width="28dp"
            android:layout_height="24dp"
            android:background="@drawable/widget_day_cell"
            android:clickable="true"
            android:contentDescription="@string/organizer_calendar_next_month"
            android:gravity="center"
            android:text="&gt;"
            android:textColor="#F5F7FF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_weekday_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_weekday_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_weekday_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_weekday_4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_weekday_5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_weekday_6"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_weekday_7"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#8F9AB8"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/widget_day_1" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_2" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_3" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_4" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_5" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_6" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_7" style="@style/WidgetDayCellText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/widget_day_8" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_9" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_10" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_11" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_12" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_13" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_14" style="@style/WidgetDayCellText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/widget_day_15" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_16" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_17" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_18" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_19" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_20" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_21" style="@style/WidgetDayCellText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/widget_day_22" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_23" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_24" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_25" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_26" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_27" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_28" style="@style/WidgetDayCellText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/widget_day_29" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_30" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_31" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_32" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_33" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_34" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_35" style="@style/WidgetDayCellText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:id="@+id/widget_day_36" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_37" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_38" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_39" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_40" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_41" style="@style/WidgetDayCellText" />
        <TextView android:id="@+id/widget_day_42" style="@style/WidgetDayCellText" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_calendar_upcoming_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_calendar_upcoming_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#AEB8D4"
            android:textSize="11sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/widget_calendar_upcoming_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cacheColorHint="@android:color/transparent"
                android:divider="@android:color/transparent"
                android:dividerHeight="6dp"
                android:fadingEdge="none"
                android:overScrollMode="never"
                android:scrollbarStyle="insideInset" />

            <TextView
                android:id="@+id/widget_calendar_upcoming_empty"
                style="@style/WidgetLineText"
                android:layout_gravity="top"
                android:background="@drawable/widget_upcoming_bubble_empty" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
