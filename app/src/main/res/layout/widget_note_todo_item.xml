<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_note_row_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_note_todo_bubble"
    android:gravity="center_vertical"
    android:minHeight="42dp"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingTop="7dp"
    android:paddingRight="10dp"
    android:paddingBottom="7dp">

    <TextView
        android:id="@+id/widget_note_checkbox"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:clickable="false"
        android:focusable="false"
        android:gravity="center"
        android:textColor="#DCE6FF"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_note_todo_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:lineSpacingExtra="2dp"
        android:textColor="#F5F7FF"
        android:textSize="13sp" />
</LinearLayout>
